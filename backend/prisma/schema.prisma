generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                         String              @id @default(uuid())
  email                      String              @unique
  passwordHash               String
  fullName                   String?
  phoneNumber                String?
  role                       String              @default("worker")
  isBlocked                  Boolean             @default(false)
  blockReason                String?
  createdAt                  DateTime            @default(now())
  pushToken                  String?
  isPhoneVerified            Boolean             @default(false)
  phoneVerificationCode      String?
  phoneVerificationExpiresAt DateTime?
  preferredGateway           String?
  stripeCustomerId           String?
  mercadopagoCustomerId      String?
  plan                       String              @default("free")
  subscriptionLevel          String              @default("basic")
  profileStatus              String              @default("active")
  planExpiresAt              DateTime?
  hasAcceptedDataSharing     Boolean             @default(false)
  dailyTokenCount            Int                 @default(0)
  lastTokenReset             DateTime?
  activityLogs               ActivityLog[]
  calculations               CalculationRecord[]
  contactRequestsSent        ContactRequest[]
  forumAnswers               ForumAnswer[]
  forumPosts                 ForumPost[]
  forumVotes                 ForumVote[]
  lawyerProfile              Lawyer?             @relation("UserAsLawyer")
  reviewsGiven               LawyerReview[]
  legalCases                 LegalCase[]
  pymeProfile                PymeProfile?
  documents                  UserDocument[]
  userRole                   UserRole?
  workerProfile              WorkerProfile?
  workerSubscription         WorkerSubscription?
  payments                   Payment[]
}

model UserDocument {
  id        String   @id @default(uuid())
  userId    String
  type      String
  url       String
  name      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model UserRole {
  id          String   @id @default(uuid())
  firebaseUid String   @unique
  role        String
  email       String
  fullName    String?
  userId      String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id])
}

model WorkerProfile {
  id                     String    @id @default(uuid())
  userId                 String    @unique
  occupation             String?
  federalEntity          String?
  startDate              DateTime?
  monthlySalary          Decimal?
  profedetIsActive       Boolean   @default(false)
  profedetStage          String?
  profedetCaseFile       String?
  profedetInitialContact String?
  profedetDocuments      String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                   User      @relation(fields: [userId], references: [id])
}

model LegalCase {
  id           String        @id @default(uuid())
  userId       String
  title        String
  status       String        @default("active")
  employerName String?
  startDate    DateTime?
  createdAt    DateTime      @default(now())
  history      CaseHistory[]
  user         User          @relation(fields: [userId], references: [id])
}

model CaseHistory {
  id          String         @id @default(uuid())
  caseId      String
  eventType   String
  description String?
  occurredAt  DateTime
  createdAt   DateTime       @default(now())
  legalCase   LegalCase      @relation(fields: [caseId], references: [id])
  evidence    EvidenceFile[]
}

model EvidenceFile {
  id              String      @id @default(uuid())
  historyId       String
  fileUrl         String
  fileType        String
  encryptionKeyId String?
  caseHistory     CaseHistory @relation(fields: [historyId], references: [id])
}

model CalculationRecord {
  id          String   @id @default(uuid())
  userId      String
  dailySalary Decimal
  startDate   DateTime
  endDate     DateTime
  resultJson  String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Lawyer {
  id                       String              @id @default(uuid())
  userId                   String              @unique
  licenseNumber            String              @unique
  specialty                String?
  professionalName         String?
  isVerified               Boolean             @default(false)
  acceptsPymeClients       Boolean             @default(false)
  strikes                  Int                 @default(0)
  status                   String              @default("ACTIVE")
  stripeCustomerId         String?
  stripePaymentMethodId    String?
  stripeSubscriptionId     String?
  subscriptionStatus       String              @default("inactive")
  subscriptionEndDate      DateTime?
  nationalScope            Boolean             @default(false)
  availableStates          String?             @default("")
  acceptsFederalCases      Boolean             @default(false)
  acceptsLocalCases        Boolean             @default(false)
  requiresPhysicalPresence Boolean             @default(true)
  physicalPresenceStates   String?             @default("")
  isCorrespondent          Boolean             @default(false)
  forumAnswers             ForumAnswer[]
  user                     User                @relation("UserAsLawyer", fields: [userId], references: [id])
  profile                  LawyerProfile?
  reviews                  LawyerReview[]
  subscription             LawyerSubscription?
  assignedPymes            PymeProfile[]
}

model LawyerProfile {
  id                        String           @id @default(uuid())
  lawyerId                  String           @unique
  photoUrl                  String?
  yearsOfExperience         Int              @default(0)
  bio                       String?
  wonCase1Summary           String?
  wonCase2Summary           String?
  wonCase3Summary           String?
  phone                     String?
  whatsapp                  String?
  attentionHours            String?
  schedule                  String?
  email                     String?
  profileViews              Int              @default(0)
  successRate               Float?           @default(0)
  reputationScore           Float            @default(50.0)
  totalCases                Int              @default(0)
  successfulCases           Int              @default(0)
  lifetimeCommissionSavings Decimal          @default(0.0)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  requests                  ContactRequest[]
  lawyer                    Lawyer           @relation(fields: [lawyerId], references: [id])
}

model WorkerSubscription {
  id              String                      @id @default(uuid())
  userId          String                      @unique
  status          String                      @default("inactive")
  startDate       DateTime?
  endDate         DateTime?
  amount          Decimal                     @default(29.00)
  paymentProvider String?
  lastPaymentId   String?
  autoRenew       Boolean                     @default(true)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  user            User                        @relation(fields: [userId], references: [id])
  payments        WorkerSubscriptionPayment[]
}

model WorkerSubscriptionPayment {
  id              String             @id @default(uuid())
  subscriptionId  String
  amount          Decimal
  status          String
  paymentDate     DateTime           @default(now())
  paymentProvider String?
  transactionId   String?
  createdAt       DateTime           @default(now())
  subscription    WorkerSubscription @relation(fields: [subscriptionId], references: [id])
}

model LawyerSubscription {
  id            String                @id @default(uuid())
  lawyerId      String                @unique
  plan          String                @default("basic")
  status        String                @default("inactive")
  startDate     DateTime?
  endDate       DateTime?
  amount        Decimal               @default(99.00)
  paymentMethod String?
  lastPaymentId String?
  autoRenew     Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  lawyer        Lawyer                @relation(fields: [lawyerId], references: [id])
  payments      SubscriptionPayment[]
}

model SubscriptionPayment {
  id             String             @id @default(uuid())
  subscriptionId String
  amount         Decimal
  status         String
  paymentDate    DateTime           @default(now())
  paymentMethod  String?
  transactionId  String?
  createdAt      DateTime           @default(now())
  subscription   LawyerSubscription @relation(fields: [subscriptionId], references: [id])
}

model ContactRequest {
  id                    String            @id @default(uuid())
  workerId              String
  lawyerProfileId       String?
  caseSummary           String
  caseType              String?
  employerName          String?
  urgency               String            @default("normal")
  estimatedSeverance    Decimal?
  urgencyScore          Int               @default(0)
  consentTimestamp      DateTime?
  dataStatus            String            @default("MASKED")
  aiSummary             String?
  crmStatus             String            @default("NEW")
  classification        String            @default("normal")
  isHot                 Boolean           @default(false)
  status                String            @default("pending")
  workerPaymentAmount   Decimal           @default(50.00)
  lawyerPaymentAmount   Decimal           @default(150.00)
  workerPaid            Boolean           @default(false)
  lawyerPaid            Boolean           @default(false)
  leadCostPaid          Decimal?
  openingFeePaid        Decimal?
  workerPaymentGateway  String?
  workerTransactionId   String?
  lawyerPaymentGateway  String            @default("stripe")
  lawyerTransactionId   String?
  bothPaymentsSucceeded Boolean           @default(false)
  refundStatus          String            @default("not_applicable")
  refundProcessedAt     DateTime?
  expiresAt             DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  acceptedAt            DateTime?
  rejectedAt            DateTime?
  expiredAt             DateTime?
  rejectionReason       String?
  rejectionCount        Int               @default(0)
  closedAt              DateTime?
  lastWorkerActivityAt  DateTime?         @default(now())
  lastLawyerActivityAt  DateTime?
  subStatus             String?
  isPaused              Boolean           @default(false)
  lastMessageContent    String?
  lastMessageSenderId   String?
  lastMessageAt         DateTime?
  unreadCountLawyer     Int               @default(0)
  unreadCountWorker     Int               @default(0)
  settlementAmount      Decimal?
  commissionRate        Decimal?
  commissionAmount      Decimal?
  commissionStatus      String            @default("not_applicable")
  commissionInvoiceId   String?
  settlementDocUrl      String?
  settlementDocStatus   String            @default("none")
  messages              ChatMessage[]
  lawyerProfile         LawyerProfile?    @relation(fields: [lawyerProfileId], references: [id])
  worker                User              @relation(fields: [workerId], references: [id])
  documents             RequestDocument[]
  payments              RequestPayment[]
}

model ChatMessage {
  id        String         @id @default(uuid())
  requestId String
  senderId  String
  content   String
  type      String         @default("text")
  status    String         @default("delivered")
  seenAt    DateTime?
  createdAt DateTime       @default(now())
  request   ContactRequest @relation(fields: [requestId], references: [id])
}

model RequestDocument {
  id         String         @id @default(uuid())
  requestId  String
  fileName   String
  fileUrl    String
  fileType   String
  fileSize   Int
  uploadedAt DateTime       @default(now())
  request    ContactRequest @relation(fields: [requestId], references: [id])
}

model RequestPayment {
  id            String         @id @default(uuid())
  requestId     String
  payer         String
  amount        Decimal
  status        String
  paymentMethod String?
  transactionId String?
  createdAt     DateTime       @default(now())
  completedAt   DateTime?
  request       ContactRequest @relation(fields: [requestId], references: [id])
}

model NewsPost {
  id        String   @id @default(uuid())
  title     String
  content   String
  sourceUrl String?
  imageUrl  String?
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model AdminAlert {
  id            String    @id @default(uuid())
  type          String
  message       String
  severity      String    @default("medium")
  isResolved    Boolean   @default(false)
  relatedUserId String?
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?
}

model LegalNews {
  id             String   @id @default(uuid())
  originalText   String
  imageUrl       String?
  titleClickable String
  summaryWorker  String
  summarySme     String
  summaryLawyer  String
  quizQuestion   String
  isPublished    Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PymeProfile {
  id                 String         @id @default(uuid())
  userId             String         @unique
  rfc                String?
  razonSocial        String?
  industry           String?
  internalRegsStatus String         @default("pending")
  assignedLawyerId   String?
  riskScore          Int            @default(50)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  documents          PymeDocument[]
  employees          PymeEmployee[]
  assignedLawyer     Lawyer?        @relation(fields: [assignedLawyerId], references: [id])
  user               User           @relation(fields: [userId], references: [id])
}

model PymeEmployee {
  id              String      @id @default(uuid())
  pymeProfileId   String
  fullName        String
  rfc             String?
  dailySalary     Decimal     @default(0.0)
  joinDate        DateTime
  contractType    String      @default("permanent")
  contractEndDate DateTime?
  isRenewed       Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  pymeProfile     PymeProfile @relation(fields: [pymeProfileId], references: [id])
}

model PymeDocument {
  id            String      @id @default(uuid())
  pymeProfileId String
  type          String
  name          String
  url           String
  fileSize      Int
  createdAt     DateTime    @default(now())
  pymeProfile   PymeProfile @relation(fields: [pymeProfileId], references: [id])
}

model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model ForumPost {
  id        String        @id @default(uuid())
  userId    String
  topic     String
  title     String
  content   String
  status    String        @default("open")
  views     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  answers   ForumAnswer[]
  user      User          @relation(fields: [userId], references: [id])
}

model ForumAnswer {
  id         String        @id @default(uuid())
  postId     String
  parentId   String?
  lawyerId   String?
  userId     String?
  content    String
  upvotes    Int           @default(0)
  isAccepted Boolean       @default(false)
  createdAt  DateTime      @default(now())
  user       User?         @relation(fields: [userId], references: [id])
  lawyer     Lawyer?       @relation(fields: [lawyerId], references: [id])
  parent     ForumAnswer?  @relation("ThreadedAnswers", fields: [parentId], references: [id])
  children   ForumAnswer[] @relation("ThreadedAnswers")
  post       ForumPost     @relation(fields: [postId], references: [id])
  votes      ForumVote[]
}

model ForumVote {
  id        String      @id @default(uuid())
  userId    String
  answerId  String
  value     Int
  createdAt DateTime    @default(now())
  answer    ForumAnswer @relation(fields: [answerId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@unique([userId, answerId])
}

model LawyerReview {
  id        String   @id @default(uuid())
  caseId    String?  @unique
  lawyerId  String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  lawyer    Lawyer   @relation(fields: [lawyerId], references: [id])
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  event     String
  metadata  String?
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
}

model StateDirectory {
  id                         Int      @id @default(autoincrement())
  stateName                  String   @unique
  profedetAddress            String?
  localProcuraduriaAddress   String?
  federalConciliationAddress String?
  localConciliationAddress   String?
  federalTribunalAddress     String?
  localTribunalAddress       String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model IndustryCompetence {
  id           Int      @id @default(autoincrement())
  sector       String
  competence   String
  baseInstance String
  keywords     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SecurityLog {
  id        String   @id @default(uuid())
  event     String   // e.g., 'LOGIN_FAILED', 'REGISTER_FAILED'
  email     String?  // The email attempted
  ipAddress String?  // The IP address of the request
  userAgent String?  // Device or browser info
  details   String?  // Additional context / error message
  createdAt DateTime @default(now())
}

model Promotion {
  id            String    @id @default(uuid())
  title         String
  description   String?
  targetRole    String    // 'ALL', 'lawyer', 'worker', 'pyme'
  type          String    // 'FREE_TRIAL', 'DISCOUNT'
  value         Int       // Days for free trial or % discount
  isActive      Boolean   @default(true)
  startDate     DateTime?
  endDate       DateTime?
  maxUses       Int?
  currentUses   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Payment {
  id                    String   @id @default(uuid())
  userId                String?
  stripeSessionId       String?  @unique
  stripePaymentIntentId String?  @unique
  status                String   @default("pending")
  type                  String
  amount                Decimal?
  currency              String?  @default("mxn")
  metadata              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User?    @relation(fields: [userId], references: [id])
}

model StripeEvent {
  id        String   @id
  type      String
  processed Boolean  @default(true)
  createdAt DateTime @default(now())
}
