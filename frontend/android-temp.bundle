__d(function(g,r,i,a,m,e,d){Object.defineProperty(e,"__esModule",{value:!0}),e.PRIVACY_NOTICES=void 0;e.PRIVACY_NOTICES={LAWYER:{title:"T\xe9rminos y Condiciones para Abogados Asociados",lastUpdate:"25 de enero de 2026",sections:[{heading:"1. OBJETO",content:"Aliado Laboral es una plataforma de intermediaci\xf3n tecnol\xf3gica que conecta a abogados con trabajadores y empresas."},{heading:"2. ESQUEMA DE COMISIONES POR \xc9XITO ('SUCCESS FEE')",content:"El Abogado acepta que, adicionalmente al costo de los Leads y la suscripci\xf3n, la Plataforma aplicar\xe1 una comisi\xf3n sobre el monto total recuperado en favor del trabajador.\n\nTABLA DE COMISIONES VIGENTE:\n- Abogado Basic/Normal: 10% (Convenio) y 8% (Sentencia).\n- Abogado PRO: 7% (Convenio) y 5% (Sentencia)."},{heading:"3. OBLIGATORIEDAD DE LA B\xd3VEDA",content:"Para el cierre de cada caso, el Abogado se obliga a cargar en la 'B\xf3veda de Documentos' el Convenio de Conciliaci\xf3n o la Sentencia correspondiente."},{heading:"4. AUDITOR\xcdA ALEATORIA Y SEGURIDAD",content:"AUDITOR\xcdA: La Plataforma se reserva el derecho de contactar al Trabajador para validar la satisfacci\xf3n y el cobro efectivo de su indemnizaci\xf3n (Auditor\xeda Social).\nSEGURIDAD: Los documentos cargados en la B\xf3veda est\xe1n protegidos con cifrado de grado bancario y se utilizan exclusivamente para fines de cumplimiento contractual y validaci\xf3n de beneficios."}]},WORKER:{title:"Aviso de Privacidad Integral para Trabajadores",lastUpdate:"25 de enero de 2026",sections:[{heading:"1. Responsable del Tratamiento",content:"\"Aliado Laboral\" protege su informaci\xf3n personal bajo los m\xe1s altos est\xe1ndares de seguridad tecnol\xf3gica."},{heading:"2. Finalidades Principales",content:"Los datos sensibles proporcionados se utilizar\xe1n exclusivamente para el c\xe1lculo de sus prestaciones y, previo consentimiento expl\xedcito, para canalizar su caso con abogados verificados."},{heading:"3. Transferencia de Informaci\xf3n",content:"Sus datos de contacto solo ser\xe1n visibles para abogados con suscripci\xf3n verificada una vez que usted decida \"Contactar a un Abogado\". No vendemos ni compartimos su informaci\xf3n con terceros ajenos a la resoluci\xf3n de su caso legal."},{heading:"4. Derechos ARCO",content:"Usted mantiene el control total. Puede acceder, rectificar o eliminar sus datos directamente desde el panel de configuraci\xf3n de la aplicaci\xf3n en cualquier momento."}]},PYME:{title:"Aviso de Privacidad Integral para PYMEs",lastUpdate:"25 de enero de 2026",sections:[{heading:"1. Tratamiento de Datos Corporativos",content:"Los datos de su plantilla laboral se procesan de forma cifrada \xfanica y exclusivamente para la generaci\xf3n de documentos internos preventivos y gesti\xf3n de riesgos laborales."},{heading:"2. Confidencialidad",content:"Aliado Laboral act\xfaa como Encargado del Tratamiento, limit\xe1ndose a proveer la infraestructura tecnol\xf3gica sin acceso o uso de los datos para fines distintos a los contratados."}]},GENERAL:{title:"Aviso de Privacidad General (Plataforma)",lastUpdate:"09 de enero de 2026",sections:[{heading:"1. Alcance",content:"Este aviso aplica a cualquier usuario (visitante, registrado o no) que acceda, navegue o utilice el sitio web y/o la aplicaci\xf3n m\xf3vil de Aliado Laboral."},{heading:"2. Datos de Navegaci\xf3n y Cookies",content:"Utilizamos cookies y tecnolog\xedas de rastreo para:\n\u2022 Reconocerlo al iniciar sesi\xf3n.\n\u2022 Analizar m\xe9tricas de tr\xe1fico y comportamiento de uso (Analytics).\n\u2022 Mejorar la seguridad del sitio.\n\nPuede deshabilitar las cookies desde la configuraci\xf3n de su navegador, aunque algunas funciones del sitio podr\xedan no operar correctamente."},{heading:"3. Formularios de Contacto",content:"Los datos (nombre, correo, mensaje) enviados a trav\xe9s de nuestros formularios de contacto o soporte ser\xe1n utilizados exclusivamente para atender su petici\xf3n, duda o comentario."},{heading:"4. Enlaces a Terceros",content:"La Plataforma puede contener enlaces a sitios externos. No nos hacemos responsables de las pr\xe1cticas de privacidad de dichos sitios."},{heading:"5. Contacto de Privacidad",content:"Para cualquier duda relacionada con la protecci\xf3n de sus datos personales, el Departamento de Privacidad de Aliado Laboral est\xe1 a sus \xf3rdenes en: vinculacion@savestudiomx.com."}]}}},1602,[]);
