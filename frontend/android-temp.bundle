__d(function(g,r,i,a,m,e,d){Object.defineProperty(e,"__esModule",{value:!0}),e.RIGHTS_GUIDES=e.RIGHTS_CHECKLIST=e.RIGHTS_CALCULATORS=void 0;e.RIGHTS_CALCULATORS=[{id:'calculadora-aguinaldo',title:'Calculadora de Aguinaldo',description:'El aguinaldo es un derecho que te corresponde por tu trabajo durante el a\xf1o. La ley establece un **m\xednimo de 15 d\xedas de salario**. \xdasala para calcular la cantidad exacta que te deben pagar, incluso si solo trabajaste una parte del a\xf1o.',icon:'gift',inputs:[{id:'fecha-ingreso-anio',label:'\xbfCu\xe1ndo empezaste a trabajar este a\xf1o?',type:'date',required:!0,infoTooltip:'Si trabajaste todo el a\xf1o, selecciona el 1 de enero. Si empezaste despu\xe9s, selecciona tu fecha de ingreso.',sourceProfileField:'startDate'},{id:'salario-diario-integrado',label:'\xbfCu\xe1l es tu Salario Diario Integrado?',type:'number',required:!0,placeholder:'Ej: 600',infoTooltip:'Calculado autom\xe1ticamente de tu salario mensual (entre 30.4). Puedes editarlo si es necesario.',sourceProfileField:'monthlySalary'}]},{id:'calculadora-vacaciones',title:'Calculadora de Vacaciones y Prima',description:'Tus d\xedas de vacaciones aumentan cada a\xf1o seg\xfan tu antig\xfcedad. Adem\xe1s, tienes derecho a una **Prima Vacacional**, que es un pago extra del 25% sobre el salario que corresponde a tus d\xedas de vacaciones. \xa1Calcula cu\xe1nto te deben!',icon:'sunny',inputs:[{id:'fecha-ingreso',label:'\xbfCu\xe1l es tu fecha de ingreso a la empresa?',type:'date',required:!0,infoTooltip:'Necesitamos esta fecha para calcular cu\xe1ntos a\xf1os llevas trabajando y as\xed saber cu\xe1ntos d\xedas de vacaciones te corresponden.',sourceProfileField:'startDate'},{id:'salario-diario-integrado',label:'\xbfCu\xe1l es tu Salario Diario Integrado?',type:'number',required:!0,placeholder:'Ej: 600',infoTooltip:'Calculado autom\xe1ticamente de tu salario mensual (entre 30.4). Puedes editarlo si es necesario.',sourceProfileField:'monthlySalary'},{id:'dias-tomados',label:'\xbfCu\xe1ntos d\xedas de vacaciones ya tomaste este a\xf1o?',type:'number',required:!1,placeholder:'Ej: 5',infoTooltip:'Opcional. Si lo pones, calcularemos el valor de los d\xedas que te faltan por disfrutar.'}]},{id:'calculadora-ptu',title:'Calculadora de PTU (Estimaci\xf3n)',description:'Estima cu\xe1nto deber\xedas recibir de PTU. Necesitar\xe1s algunos datos de la empresa o realizar estimaciones.',icon:'cash',inputs:[{id:'numero-trabajadores',label:'N\xfamero total de trabajadores en la empresa',type:'number',required:!0,placeholder:'Ej: 50',infoTooltip:'Es el n\xfamero total de empleados, incluyendo a todos los niveles.'},{id:'utilidad-empresa',label:'Utilidad Gravable de la empresa (opcional)',type:'number',required:!1,placeholder:'Ej: 5000000',infoTooltip:'Si no tienes este dato, puedes dejarlo vac\xedo y usaremos el tope legal (3 meses) para darte una estimaci\xf3n m\xe1xima.'},{id:'salario-anual',label:'Tu salario anual bruto',type:'number',required:!0,placeholder:'Ej: 180000',infoTooltip:'Es tu salario mensual multiplicado por 12, m\xe1s otras percepciones anuales como aguinaldo.'},{id:'suma-salarios-todos',label:'Suma de salarios de todos los trabajadores',type:'number',required:!1,placeholder:'Ej: 9000000',infoTooltip:'Dato dif\xedcil de conseguir. Si lo dejas vac\xedo, estimaremos usando tu salario como promedio (poco preciso pero \xfatil como referencia).'}]},{id:'herramienta-consulta-infonavit',title:'Mi Consultor INFONAVIT',description:'Te guiaremos paso a paso para que conozcas tu situaci\xf3n actual en el INFONAVIT y sepas qu\xe9 puedes hacer.',icon:'search',inputs:[]},{id:'herramienta-consulta-fonacot',title:'Mi Consultor FONACOT',description:'Te guiaremos paso a paso para que sepas si eres elegible y c\xf3mo empezar tu proceso de cr\xe9dito.',icon:'card',inputs:[]}],e.RIGHTS_GUIDES=[{id:'guia-rapida-ptu',title:'Gu\xeda del Reparto de Utilidades (PTU)',description:'Descubre si tu empresa debe darte utilidades, cu\xe1ndo se pagan y cu\xe1nto te podr\xeda tocar.',icon:'cash',content:"\n# \xbfQu\xe9 es la PTU?\nEs el derecho constitucional de los trabajadores a recibir una parte de las ganancias que obtuvo la empresa o patr\xf3n en el a\xf1o anterior.\n\n## \xbfCu\xe1ndo se paga?\n- **Empresas (Personas Morales):** A m\xe1s tardar el 30 de mayo.\n- **Patrones (Personas F\xedsicas):** A m\xe1s tardar el 29 de junio.\n\n## \xbfQui\xe9nes tienen derecho?\n- Trabajadores que hayan laborado **al menos 60 d\xedas** en el a\xf1o.\n- Trabajadores de planta o eventuales.\n\n## \xbfQui\xe9nes NO reciben?\n- Directores, administradores y gerentes generales.\n- Socios y accionistas.\n- Trabajadores dom\xe9sticos.\n- Quienes trabajaron menos de 60 d\xedas en el a\xf1o.\n\n## \xbfC\xf3mo se calcula?\nLa empresa reparte el 10% de sus utilidades netas. Ese monto se divide en dos partes iguales:\n1. **50%:** Se reparte igual entre todos los trabajadores, considerando los d\xedas trabajados.\n2. **50%:** Se reparte proporcionalmente seg\xfan el salario de cada trabajador.\n\n**\xa1Ojo!** Si la empresa declara que no tuvo ganancias, no hay reparto.\n        "},{id:'guia-rapida-infonavit',title:'Gu\xeda R\xe1pida de INFONAVIT',description:'Entiende c\xf3mo funciona tu cr\xe9dito de vivienda, los puntos necesarios y tus derechos ante el instituto.',icon:'home',content:"\n# Tu Derecho a la Vivienda (INFONAVIT)\nEl patr\xf3n debe aportar el **5% de tu salario** a tu Subcuenta de Vivienda. Este dinero es tuyo y sirve para pedir un cr\xe9dito o para tu retiro.\n\n## \xbfPara qu\xe9 sirve el cr\xe9dito?\n1. **Comprar:** Casa nueva o usada.\n2. **Construir:** En un terreno propio.\n3. **Mejorar:** Ampliar o reparar tu casa actual.\n4. **Pagar:** Una hipoteca que tengas con un banco.\n\n## Los famosos \"Puntos\"\nNecesitas **1080 puntos** para solicitar un cr\xe9dito. Los puntos se calculan con:\n- Tu edad y salario.\n- Tu ahorro en la Subcuenta de Vivienda.\n- La cotizaci\xf3n continua (tiempo sin dejar de trabajar).\n- El tipo de trabajador (permanente o eventual).\n- La estabilidad laboral de la empresa.\n\n## \xbfQu\xe9 pasa si pierdo mi empleo?\nTienes derecho a un seguro de desempleo (Fondo de Protecci\xf3n de Pagos) por hasta 6 meses, donde solo pagas el 10% de la mensualidad. \xa1Contacta al INFONAVIT de inmediato si esto pasa!\n        "},{id:'guia-rapida-fonacot',title:'Gu\xeda R\xe1pida de FONACOT',description:'Aprende a usar FONACOT, tu beneficio para acceder a cr\xe9ditos con mejores condiciones que en la banca.',icon:'card',content:"\n# \xbfQu\xe9 es FONACOT?\n\nFONACOT (Fondo Nacional del Consumo para los Trabajadores) es un beneficio que tienes como trabajador afiliado al IMSS para acceder a cr\xe9ditos personales, hipotecarios o para tu negocio, con tasas de inter\xe9s m\xe1s bajas y pagos fijos que se descuentan directamente de tu n\xf3mina.\n\n## \xbfQui\xe9n puede solicitar un cr\xe9dito?\n\nTodos los trabajadores que:\n- Est\xe9n dados de alta en el IMSS.\n- Tengan una antig\xfcedad m\xednima en su trabajo actual (generalmente 6 meses).\n- Cuenten con una capacidad de endeudamiento disponible.\n\n## Tipos de Cr\xe9ditos m\xe1s Comunes\n\n1. **Cr\xe9dito Personal:** Para cualquier necesidad: emergencias, vacaciones, estudios, etc.\n2. **Cr\xe9dito Hipotecario:** Para comprar, construir o mejorar tu vivienda.\n3. **Cr\xe9dito para Negocios (PYME):** Si quieres emprender o hacer crecer tu propio negocio.\n\n## \xbfC\xf3mo se Paga el Cr\xe9dito?\n\nLa gran ventaja es que los pagos se hacen **autom\xe1ticamente**. Tu patr\xf3n descuenta la mensualidad de tu sueldo y se la paga directamente a FONACOT. No tienes que preocuparte por hacer transferencias ni ir al banco.\n\n## \xbfY si mi patr\xf3n no quiere hacer el descuento?\n\nTu patr\xf3n est\xe1 **obligado por ley** a realizar el descuento de n\xf3mina si el cr\xe9dito te fue aprobado. Si se niega, puedes denunciarlo ante el IMSS o la Procuradur\xeda de la Defensa del Trabajo (PROFEDET).\n\n**Usa nuestra Herramienta de Consulta para saber los primeros pasos.**\n        "}],e.RIGHTS_CHECKLIST=[{id:'checklist-contrato',title:'Contrato por Escrito',description:'Es tu garant\xeda legal. Sin \xe9l, es dif\xedcil probar tus condiciones laborales.',icon:'document-text',userQuestion:'\xbfTienes una copia firmada de tu contrato individual de trabajo?',relatedProblemId:'despido_injustificado'},{id:'checklist-imss',title:'Alta en el IMSS',description:'Garantiza tu salud y tu ahorro para el retiro.',icon:'medkit',userQuestion:'\xbfVerificaste en la app del IMSS que est\xe1s dado de alta con tu salario real?',relatedProblemId:'no_me_dan_derechos'},{id:'checklist-recibo',title:'Recibos de N\xf3mina',description:'Comprueban tus ingresos y descuentos oficiales.',icon:'receipt',userQuestion:'\xbfRecibes peri\xf3dicamente (semanal/quincenal) un recibo de n\xf3mina timbrado (CFDI)?',relatedProblemId:'no_me_pagan'},{id:'checklist-vacaciones',title:'Vacaciones Dignas',description:'Descanso pagado para reponer energ\xedas.',icon:'airplane',userQuestion:'\xbfDisfrutaste de al menos 12 d\xedas de vacaciones en tu primer a\xf1o de trabajo?',relatedProblemId:'no_me_dan_derechos'},{id:'checklist-jornada',title:'Jornada Laboral',description:'L\xedmites de tiempo para evitar la explotaci\xf3n.',icon:'time',userQuestion:'\xbfTrabajas m\xe1ximo 48 horas a la semana (turno diurno) sin que las horas extra sean obligatorias?',relatedProblemId:'no_me_pagan'}]},1624,[]);
