__d(function(g,r,i,a,m,e,d){Object.defineProperty(e,"__esModule",{value:!0}),e.BENEFITS_DATA=void 0;e.BENEFITS_DATA=[{id:'aguinaldo',title:'Aguinaldo',icon:'gift',description:'Es una prestaci\xf3n que te corresponde por tu trabajo durante el a\xf1o. La ley establece un m\xednimo de 15 d\xedas de salario, sin importar el tiempo que hayas trabajado en el mismo.',keyInfo:['M\xednimo de 15 d\xedas de tu salario.','Se paga de forma proporcional si no trabajaste el a\xf1o completo.','La fecha l\xedmite de pago es antes del 20 de diciembre.'],calculatorId:'calculadora-aguinaldo',whatIfIDontGetIt:{title:'\xbfY si no me lo pagan?',description:'Es una violaci\xf3n a tus derechos. Puedes exigirlo mediante una demanda.',relatedProblemId:'no_me_pagan'}},{id:'vacaciones_prima',title:'Vacaciones y Prima Vacacional',icon:'sunny',description:'Tienes derecho a d\xedas de descanso pagados que aumentan con tu antig\xfcedad, m\xe1s un pago extra del 25% sobre esos d\xedas.',keyInfo:['12 d\xedas m\xednimos el primer a\xf1o.','Aumentan 2 d\xedas por a\xf1o hasta llegar a 20.','La prima vacacional es el 25% extra de tu salario diario durante las vacaciones.'],calculatorId:'calculadora-vacaciones',whatIfIDontGetIt:{title:'\xbfY si no me dan vacaciones?',description:'Las vacaciones no se pueden cambiar por dinero (salvo al terminar la relaci\xf3n laboral). Debes disfrutarlas.',relatedProblemId:'no_me_dan_derechos'}},{id:'ptu',title:'Reparto de Utilidades (PTU)',icon:'cash',description:'Es tu derecho a recibir una parte de las ganancias que obtuvo la empresa el a\xf1o anterior.',keyInfo:['La empresa debe repartir el 10% de sus utilidades netas.','Se paga a m\xe1s tardar el 30 de mayo (empresas) o 29 de junio (patrones).','Debes haber trabajado al menos 60 d\xedas en el a\xf1o.'],calculatorId:'calculadora-ptu',whatIfIDontGetIt:{title:'\xbfY si no hubo reparto?',description:'Si la empresa declar\xf3 ganancias y no te pag\xf3, puedes denunciar.',relatedProblemId:'no_me_pagan'}},{id:'prima_dominical',title:'Prima Dominical',icon:'calendar',description:'Si trabajas ordinariamente en domingo, tienes derecho a un pago adicional.',keyInfo:['Es un 25% extra sobre tu salario de ese d\xeda.','Aplica si tu d\xeda de descanso es cualquier otro d\xeda de la semana.'],whatIfIDontGetIt:{title:'\xbfY si no me la pagan?',description:'Revisa tus recibos de n\xf3mina. Si trabajas los domingos, este concepto debe aparecer desglosado.',relatedProblemId:'no_me_pagan'}},{id:'dia_descanso',title:'D\xeda de Descanso Semanal',icon:'beer',description:'Por cada 6 d\xedas de trabajo, tienes derecho a disfrutar de un d\xeda de descanso con goce de salario \xedntegro.',keyInfo:['M\xednimo 1 d\xeda a la semana.','Preferentemente debe ser el domingo.','Si te piden trabajar tu d\xeda de descanso, deben pagarte el DOBL\xc9 del salario (200% extra).'],whatIfIDontGetIt:{title:'\xbfMe obligan a trabajar sin descanso?',description:'Es ilegal. Tienes derecho a tu descanso o al pago triple (salario normal + doble por el descanso trabajado).',relatedProblemId:'no_me_dan_derechos'}},{id:'dias_festivos',title:'D\xedas Festivos Obligatorios',icon:'flag',description:'Son d\xedas de descanso obligatorio se\xf1alados por la ley (ej. 1 de enero, 16 de septiembre, 25 de diciembre).',keyInfo:['Si descansas, te pagan tu sueldo normal.','Si trabajas, te deben pagar tu salario normal M\xc1S el doble (Pago Triple en total).'],whatIfIDontGetIt:{title:'\xbfMe hicieron trabajar en festivo?',description:'Debes recibir el pago triple por ese d\xeda. Revisa tu n\xf3mina.',relatedProblemId:'no_me_pagan'}},{id:'periodo_vacacional',title:'Periodo Vacacional Continuo',icon:'airplane',description:'Tus d\xedas de vacaciones deben concederse, por lo menos, 12 d\xedas continuos.',keyInfo:['T\xfa decides si quieres fraccionarlos o tomarlos juntos.','La empresa no puede imponerte las fechas arbitrariamente sin acuerdo.'],whatIfIDontGetIt:{title:'\xbfNo me dejan tomar vacaciones?',description:'Es tu derecho y caduca al a\xf1o y medio. \xa1Ex\xedgelas por escrito!',relatedProblemId:'no_me_dan_derechos'}},{id:'imss',title:'Seguridad Social (IMSS)',icon:'medkit',description:'Tu inscripci\xf3n al IMSS te da derecho a atenci\xf3n m\xe9dica gratuita, pago de incapacidades y pensiones.',keyInfo:['Cubre enfermedades, maternidad, riesgos de trabajo, invalidez y vejez.','Protege tambi\xe9n a tus beneficiarios (hijos, esposa/o, padres).','Debes estar registrado con tu Salario Real.'],relatedGuideId:'checklist-imss',whatIfIDontGetIt:{title:'\xbfNo est\xe1s dado de alta?',description:'Es un delito grave de tu patr\xf3n. Est\xe1s desprotegido ante accidentes.',relatedProblemId:'no_me_dan_derechos'}},{id:'afore',title:'Ahorro para el Retiro (AFORE)',icon:'trending-up',description:'Es una cuenta individual donde se acumulan tus ahorros para cuando te jubiles.',keyInfo:['El patr\xf3n aporta el 2% de tu salario base.','T\xfa tambi\xe9n aportas una parte.','Puedes hacer aportaciones voluntarias para mejorar tu pensi\xf3n.'],whatIfIDontGetIt:{title:'\xbfNo tienes Afore?',description:'Si tienes IMSS, tienes Afore. Verifica en qu\xe9 banco est\xe1 con tu CURP.',relatedProblemId:'no_me_dan_derechos'}},{id:'infonavit',title:'INFONAVIT (Vivienda)',icon:'home',description:'Derecho a un cr\xe9dito barato para comprar, construir o mejorar tu vivienda.',keyInfo:['El patr\xf3n aporta el 5% de tu salario (sin descont\xe1rtelo).','Ese dinero se acumula en tu Subcuenta de Vivienda.','Necesitas 1080 puntos para pedir un cr\xe9dito.'],calculatorId:'herramienta-consulta-infonavit',relatedGuideId:'guia-rapida-infonavit',whatIfIDontGetIt:{title:'\xbfY si mi patr\xf3n no paga?',description:'Te afecta para obtener tu cr\xe9dito. Den\xfancialo ante el INFONAVIT.',relatedProblemId:'no_me_dan_derechos'}}]},1730,[]);
