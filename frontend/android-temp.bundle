__d(function(g,r,i,a,m,e,d){Object.defineProperty(e,"__esModule",{value:!0}),e.COMMON_PROBLEMS=void 0;e.COMMON_PROBLEMS=[{id:'despido_injustificado',title:'Despido Injustificado',icon:'\ud83d\udd34',description:'Es cuando tu empleador termina tu relaci\xf3n laboral sin una causa justificada, sin notificarte por escrito o sin pagarte las indemnizaciones que la ley establece.',howToKnowTitle:'\xbfC\xf3mo saber si es tu caso?',howToKnowPoints:['\xbfTe despidieron sin darte una raz\xf3n clara y por escrito?','\xbfTe acusaron de algo que no hiciste sin pruebas?','\xbfTe despidieron por estar embarazada, por tu edad, por tu orientaci\xf3n sexual o por alguna otra discriminaci\xf3n?','\xbfTe ofrecieron "renunciar voluntariamente" a cambio de un pago que parece muy bajo?'],whatToDoTitle:'\xbfQu\xe9 hacer AHORA? (Pasos Inmediatos)',whatToDoPoints:[{action:'NO firmes tu renuncia',detail:'ni ning\xfan documento (finiquito, recibo) sin entenderlo bien.'},{action:'Pide por escrito',detail:'tu finiquito y tus documentos de trabajo (constancias, etc.).'},{action:'Guarda pruebas',detail:'(correos, mensajes de WhatsApp, grabaciones, testigos).'},{action:'Tienes 2 meses',detail:'para iniciar un juicio. \xa1No dejes pasar el tiempo!'}],nextStepsTitle:'Tu Siguiente Paso en la App',nextSteps:[{action:'Calcula tu finiquito',detail:'con nuestra herramienta para saber cu\xe1nto te deben.',targetModule:'Calculator'},{action:'Contacta a un abogado',detail:'para evaluar tu caso y defender tus derechos.',targetModule:'Lawyers'}]},{id:'no_me_pagan',title:'No me pagan (horas extra, salario, prestaciones)',icon:'\ud83d\udcb8',description:'Cuando tu empleador no te paga tu salario completo, las horas extra que trabajaste, o te niega prestaciones como vacaciones, reparto de utilidades (PTU) o aguinaldo.',howToKnowTitle:'\xbfC\xf3mo saber si es tu caso?',howToKnowPoints:['\xbfTu recibo de n\xf3mina no coincide con las horas que trabajaste?','\xbfTrabajas horas extras y no te pagan el 100% extra?','\xbfNo te han dado tus vacaciones de ley o te las pagan sin el prima vacacional?','\xbfNo te han pagado el aguinaldo o la PTU correspondiente?'],whatToDoTitle:'\xbfQu\xe9 hacer AHORA? (Pasos Inmediatos)',whatToDoPoints:[{action:'Guarda tus recibos de n\xf3mina',detail:'y cualquier comprobante de tus horas de trabajo.'},{action:'Anota tus horas extra',detail:'en una libreta o en tu celular, con fecha y hora.'},{action:'Solicita un estado de cuenta',detail:'de tus prestaciones por escrito a Recursos Humanos.'},{action:'No renuncies',detail:'por esta causa, podr\xedas perder el derecho a una indemnizaci\xf3n.'}],nextStepsTitle:'Tu Siguiente Paso en la App',nextSteps:[{action:'Usa nuestra Calculadora',detail:'para saber cu\xe1nto te deben.',targetModule:'Calculator'},{action:'Revisa tus Prestaciones de Ley',detail:'para conocer tus derechos.',targetModule:'Benefits'}]},{id:'acoso_laboral',title:'Acoso Laboral (Mobbing)',icon:{type:'image',value:r(d[0])},description:'Es el comportamiento hostil, ofensivo o intimidatorio que se repite de forma sistem\xe1tica por parte de jefes o compa\xf1eros, creando un ambiente de trabajo humillante y da\xf1ino para tu dignidad.',howToKnowTitle:'\xbfC\xf3mo saber si es tu caso?',howToKnowPoints:['\xbfTe ignoran, te a\xedslan o te asignan tareas humillantes constantemente?','\xbfRecibes cr\xedticas injustificadas y p\xfablicas sobre tu trabajo?','\xbfTe hacen chistes o comentarios ofensivos sobre tu persona?','\xbfDifunden rumores falsos para da\xf1ar tu reputaci\xf3n en la empresa?'],whatToDoTitle:'\xbfQu\xe9 hacer AHORA? (Pasos Inmediatos)',whatToDoPoints:[{action:'Documenta cada incidente',detail:'con fecha, hora, descripci\xf3n y testigos (si los hay).'},{action:'Guarda pruebas',detail:'(correos, mensajes, notas, etc.).'},{action:'Informa a Recursos Humanos',detail:'por escrito, si te sientes seguro de hacerlo.'},{action:'Busca apoyo psicol\xf3gico',detail:'tu salud es la prioridad.'}],nextStepsTitle:'Tu Siguiente Paso en la App',nextSteps:[{action:'Consulta la NOM-035',detail:'sobre Factores de Riesgo Psicosocial.',targetModule:'ImssNom'},{action:'Habla con un abogado',detail:'especializado en acoso laboral.',targetModule:'Lawyers'}]},{id:'ciberacoso_laboral',title:'Ciberacoso Laboral',icon:{type:'image',value:r(d[1])},description:'Es el acoso, hostigamiento, humillaci\xf3n o amenaza que sufres a trav\xe9s de medios digitales como WhatsApp, correo electr\xf3nico, redes sociales o cualquier plataforma online, por parte de un jefe, compa\xf1ero o incluso la empresa.',howToKnowTitle:'\xbfC\xf3mo saber si es tu caso?',howToKnowPoints:['\xbfTe env\xedan mensajes ofensivos, insultantes o amenazantes fuera de tu horario laboral?','\xbfPublican fotos, videos o informaci\xf3n tuya para ridiculizarte o da\xf1ar tu reputaci\xf3n?','\xbfTe han excluido de grupos de trabajo importantes en WhatsApp o Slack sin justificaci\xf3n?','\xbfUsan el email de la empresa para difundir rumores falsos sobre ti?'],whatToDoTitle:'\xbfQu\xe9 hacer AHORA? (Pasos Inmediatos)',whatToDoPoints:[{action:'NO BORRES NADA',detail:'Haz capturas de pantalla de todo: mensajes, publicaciones, correos.'},{action:'Bloquea al agresor',detail:'en redes sociales y WhatsApp, pero solo DESPU\xc9S de haber guardado las pruebas.'},{action:'Informa a Recursos Humanos',detail:'por escrito (env\xeda un email), describiendo los hechos y adjuntando las pruebas.'},{action:'Busca apoyo',detail:'Habla con alguien de confianza o un profesional. Tu salud mental es lo primero.'}],nextStepsTitle:'Tu Siguiente Paso en la App',nextSteps:[{action:'Re\xfane todas tus pruebas digitales',detail:'en una carpeta.',targetModule:'MyChest'},{action:'Habla con un abogado',detail:'especializado en derecho digital y laboral.',targetModule:'Lawyers'}]},{id:'no_me_dan_derechos',title:'No me dan mis derechos (IMSS, vacaciones, etc.)',icon:'\ud83d\udcc4',description:'Cuando tu empleador no cumple con sus obligaciones legales de inscribirte en el IMSS, darte tus vacaciones, pagar tu aguinaldo o repartir utilidades (PTU).',howToKnowTitle:'\xbfC\xf3mo saber si es tu caso?',howToKnowPoints:['\xbfNo tienes tu n\xfamero de afiliaci\xf3n al IMSS o no apareces en su app?','\xbfLlevas m\xe1s de un a\xf1o trabajando y nunca te has ido de vacaciones?','\xbfNo te han entregado tu aguinaldo antes del 20 de diciembre?','\xbfLa empresa reparte utilidades y t\xfa no recibiste nada?'],whatToDoTitle:'\xbfQu\xe9 hacer AHORA? (Pasos Inmediatos)',whatToDoPoints:[{action:'Solicita tu constancia de trabajo',detail:'y tus comprobantes de inscripci\xf3n en el IMSS.'},{action:'Revisa tus recibos de n\xf3mina',detail:'para ver si est\xe1n realizando las deducciones correctas.'},{action:'Presenta un escrito libre',detail:'en la oficina del IMSS m\xe1s cercana para verificar tu inscripci\xf3n.'},{action:'Guarda todos tus comprobables',detail:'de trabajo (contratos, correos, etc.).'}],nextStepsTitle:'Tu Siguiente Paso en la App',nextSteps:[{action:'Usa nuestra Calculadora',detail:'para saber cu\xe1nto te deben.',targetModule:'Calculator'},{action:'Genera una carta de solicitud',detail:'en "Mi Ba\xfal" para exigir tus derechos.',targetModule:'MyChest'}]},{id:'presion_firmar',title:'Presi\xf3n para firmar (renuncia, finiquito)',icon:'\u270d\ufe0f',description:'Cuando tu empleador te presiona, enga\xf1a o coacciona para que firmes una renuncia voluntaria, un finiquito o un recibo de pago con montos inferiores a los que legalmente te corresponden.',howToKnowTitle:'\xbfC\xf3mo saber si es tu caso?',howToKnowPoints:['\xbfTe dicen que si no firmas "la renuncia", no te dar\xe1n tu \xfaltimo pago?','\xbfTe ofrecen un "acuerdo r\xe1pido" si renuncias, pero el dinero es muy bajo?','\xbfTe presionan para que firmes un documento "de confianza" sin dejarte leerlo con calma?','\xbfTe amenazan con demandarte o da\xf1ar tu reputaci\xf3n si no firmas?'],whatToDoTitle:'\xbfQu\xe9 hacer AHORA? (Pasos Inmediatos)',whatToDoPoints:[{action:'NO firmes NADA',detail:'a la que te presionen. Tienes derecho a leerlo y entenderlo.'},{action:'Pide una copia del documento',detail:'antes de firmarlo para poder analizarlo.'},{action:'Graba la conversaci\xf3n',detail:'si te sientes seguro, como prueba de la presi\xf3n.'},{action:'Ret\xedrate del lugar',detail:'si la situaci\xf3n es muy hostil. No tienes que firmar en ese momento.'}],nextStepsTitle:'Tu Siguiente Paso en la App',nextSteps:[{action:'Calcula tu finiquito real',detail:'con nuestra herramienta para comparar.',targetModule:'Calculator'},{action:'Contacta a un abogado',detail:'antes de firmar cualquier documento.',targetModule:'Lawyers'}]}]},1519,[1520,1521]);
