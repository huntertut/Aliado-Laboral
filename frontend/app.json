{
  "expo": {
    "name": "Aliado Laboral",
    "slug": "aliado-laboral",
    "version": "1.18.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/aliado_logo_new.png",
    "splash": {
      "image": "./assets/images/aliado_logo_new.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e3799"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aliadolaboral.app"
    },
    "android": {
      "package": "com.aliadolaboral.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/aliado_logo_new.png",
        "backgroundColor": "#1e3799"
      },
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-local-authentication"
    ],
    "updates": {
      "url": "https://u.expo.dev/edbaa94d-8deb-4e42-9eae-b9d597dcf595"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "extra": {
      "eas": {
        "projectId": "edbaa94d-8deb-4e42-9eae-b9d597dcf595"
      }
    }
  }
}